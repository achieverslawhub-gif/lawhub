# Supabase — from Project Settings > API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — from resend.com/api-keys (used to send you email notifications)
RESEND_API_KEY=your-resend-api-key

# Where booking/request notifications get sent
ADMIN_NOTIFY_EMAIL=adeoluwaolodude@gmail.com

# The email address Resend sends FROM. Until you verify your own domain on
# Resend, you must use their shared testing address below.
NOTIFY_FROM_EMAIL=Achievers Law Hub <onboarding@resend.dev>
